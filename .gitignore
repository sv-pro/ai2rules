/target
**/*.rs.bk
# wasm-pack build output (regenerated; see crates/harness-wasm) (E14)
crates/harness-wasm/pkg/
crates/harness-wasm/pkg-web/
# Note: the size-optimized release wasm under blog/public/vendor/harness-wasm/
# IS committed (it ships with the Cloudflare Pages deploy); only the wasm-pack
# build dirs above are ignored. Regenerate with:
#   wasm-pack build crates/harness-wasm --target web --release --out-dir pkg-web
# Reference projects (separate git repos kept for study, never committed here).
/repos/

# Claude Code local/runtime state
.claude/settings.local.json
.claude/state/

# Python bytecode (the .claude/hooks/*.py gate hooks generate this)
__pycache__/
*.pyc
